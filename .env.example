# Copy this file to .env and edit values for your environment.
# Docker Compose automatically reads .env from the project root.

# Prebuilt image tags (GHCR)
CRIKKET_WEB_IMAGE=ghcr.io/redpangilinan/crikket-web:latest
CRIKKET_SERVER_IMAGE=ghcr.io/redpangilinan/crikket-server:latest

# Published ports on host
WEB_PORT=3001
SERVER_PORT=3000
POSTGRES_PORT=5432

# Optional: bundled postgres service settings only
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crikket
POSTGRES_HOST_AUTH_METHOD=false
