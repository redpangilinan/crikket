{
  "extends": "@crikket/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "composite": true,
    "strictNullChecks": true,
    "paths": {
      "@crikket/ui/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}
